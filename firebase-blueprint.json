{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "Information about a graduating student.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the student."
        },
        "name": {
          "type": "string",
          "description": "Full name of the student."
        },
        "nickname": {
          "type": "string",
          "description": "Nickname or school alias."
        },
        "image": {
          "type": "string",
          "description": "URL of the student's portrait image."
        },
        "favoriteMemory": {
          "type": "string",
          "description": "Their favorite memory from school."
        },
        "messageToClassmates": {
          "type": "string",
          "description": "Farewell or inspirational message."
        },
        "aspirations": {
          "type": "string",
          "description": "Future goals or aspirations."
        },
        "house": {
          "type": "string",
          "description": "School sport or performance house name."
        }
      },
      "required": ["id", "name", "nickname", "image", "favoriteMemory", "messageToClassmates"]
    },
    "Superlative": {
      "title": "Superlative",
      "description": "Award categories voted on or given to students.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the superlative."
        },
        "category": {
          "type": "string",
          "description": "Name of the superlative category."
        },
        "description": {
          "type": "string",
          "description": "What this category represents."
        },
        "studentName": {
          "type": "string",
          "description": "Name of the winning student."
        },
        "studentImage": {
          "type": "string",
          "description": "Portrait image URL of the winning student."
        }
      },
      "required": ["id", "category", "description", "studentName", "studentImage"]
    },
    "TeacherTribute": {
      "title": "TeacherTribute",
      "description": "A tribute or thank you card for a teacher.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the tribute."
        },
        "name": {
          "type": "string",
          "description": "Teacher's name."
        },
        "subject": {
          "type": "string",
          "description": "Subject taught by the teacher."
        },
        "image": {
          "type": "string",
          "description": "Image URL of the teacher."
        },
        "message": {
          "type": "string",
          "description": "Farewell/thank you message."
        }
      },
      "required": ["id", "name", "subject", "image", "message"]
    },
    "TimelineEvent": {
      "title": "TimelineEvent",
      "description": "A major milestone event during the school year.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the event."
        },
        "date": {
          "type": "string",
          "description": "Date of the event."
        },
        "title": {
          "type": "string",
          "description": "Title of the event."
        },
        "description": {
          "type": "string",
          "description": "Detailed description of what occurred."
        },
        "image": {
          "type": "string",
          "description": "Event snapshot photo URL."
        }
      },
      "required": ["id", "date", "title", "description", "image"]
    },
    "GuestbookEntry": {
      "title": "GuestbookEntry",
      "description": "A message left by students, parents, teachers, well-wishers.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the entry."
        },
        "name": {
          "type": "string",
          "description": "Visitor's name."
        },
        "role": {
          "type": "string",
          "description": "Role of the visitor.",
          "enum": ["Student", "Parent", "Teacher", "Alumni", "Well-wisher"]
        },
        "message": {
          "type": "string",
          "description": "Guestbook comment/well wishes."
        },
        "timestamp": {
          "type": "string",
          "description": "When the entry was posted."
        },
        "imageUrl": {
          "type": "string",
          "description": "Optional attached image."
        },
        "selectedDate": {
          "type": "string",
          "description": "Optional custom date selected."
        }
      },
      "required": ["id", "name", "role", "message", "timestamp"]
    },
    "VideoMemory": {
      "title": "VideoMemory",
      "description": "A student-submitted video memory.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the video."
        },
        "title": {
          "type": "string",
          "description": "Title of the video memory."
        },
        "submittedBy": {
          "type": "string",
          "description": "Contributor's name."
        },
        "role": {
          "type": "string",
          "description": "Role of the contributor."
        },
        "url": {
          "type": "string",
          "description": "Video streaming/embed link."
        },
        "thumbnailUrl": {
          "type": "string",
          "description": "Optional video thumbnail image URL."
        },
        "uploadedAt": {
          "type": "string",
          "description": "Date and time of submission."
        }
      },
      "required": ["id", "title", "submittedBy", "role", "url", "uploadedAt"]
    },
    "Photo": {
      "title": "Photo",
      "description": "An approved graduation photo entry in the shared gallery.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the photo."
        },
        "url": {
          "type": "string",
          "description": "Image URL on Cloudinary or static asset."
        },
        "title": {
          "type": "string",
          "description": "Brief description of the photo."
        },
        "submittedBy": {
          "type": "string",
          "description": "Name of the person who uploaded it."
        },
        "role": {
          "type": "string",
          "description": "Role of the uploader."
        },
        "uploadedAt": {
          "type": "string",
          "description": "ISO timestamp when uploaded."
        }
      },
      "required": ["id", "url", "title", "submittedBy", "role", "uploadedAt"]
    },
    "AdminUser": {
      "title": "AdminUser",
      "description": "An authorized administrator email address.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "Normalized administrator email."
        },
        "addedAt": {
          "type": "string",
          "description": "ISO timestamp when authorized."
        },
        "addedBy": {
          "type": "string",
          "description": "Email of the admin who authorized them."
        }
      },
      "required": ["email", "addedAt", "addedBy"]
    },
    "CustomSection": {
      "title": "CustomSection",
      "description": "A dynamic customizable presentation section managed by the admin.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier."
        },
        "title": {
          "type": "string",
          "description": "Section title."
        },
        "subtext": {
          "type": "string",
          "description": "Supporting copy."
        },
        "mediaUrl": {
          "type": "string",
          "description": "Optional image/video asset link."
        },
        "mediaType": {
          "type": "string",
          "enum": ["image", "video", "none"]
        },
        "orderIndex": {
          "type": "integer"
        },
        "layoutType": {
          "type": "string",
          "enum": ["standard", "birthday", "announcement", "spotlight"]
        },
        "visible": {
          "type": "boolean"
        },
        "subLabel": {
          "type": "string"
        }
      },
      "required": ["id", "title", "subtext", "orderIndex"]
    },
    "PendingSubmission": {
      "title": "PendingSubmission",
      "description": "A contribution waiting in the moderation queue.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["guestbook", "student_add", "student_portrait_update", "timeline", "video_memory", "teacher_tribute", "photo"]
        },
        "submittedAt": {
          "type": "string"
        },
        "data": {
          "type": "object"
        }
      },
      "required": ["id", "type", "submittedAt", "data"]
    }
  },
  "firestore": {
    "guestbook": {
      "schema": "GuestbookEntry",
      "description": "Public guestbook records."
    },
    "students": {
      "schema": "Student",
      "description": "Graduating students' database profile list."
    },
    "timeline": {
      "schema": "TimelineEvent",
      "description": "Shared timeline/history events."
    },
    "videos": {
      "schema": "VideoMemory",
      "description": "Graduation/class dynamic video memory uploads."
    },
    "submissions": {
      "schema": "PendingSubmission",
      "description": "Moderation storage for pending items."
    },
    "admins": {
      "schema": "AdminUser",
      "description": "Authorized emails allowed to perform administrator functions."
    },
    "photos": {
      "schema": "Photo",
      "description": "A list of shared highlight pictures."
    },
    "superlatives": {
      "schema": "Superlative",
      "description": "Awards and titles won by pupils."
    },
    "teacher_tributes": {
      "schema": "TeacherTribute",
      "description": "Messages appreciating the tutorial staff."
    },
    "settings": {
      "schema": "object",
      "description": "Global layout, order, toggles, or logo assets."
    },
    "custom_sections": {
      "schema": "CustomSection",
      "description": "Dynamically added segments of content."
    }
  }
}
